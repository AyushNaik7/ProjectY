rules_version = '2';

/**
 * Firestore Security Rules — Production SaaS Architecture
 *
 * PRINCIPLE: The frontend is UNTRUSTED. All writes go through Cloud Functions.
 *
 * Architecture:
 *   Firebase Auth → Cloud Functions (server-side validation) → Admin SDK → Firestore
 *
 * These rules ONLY allow direct reads where needed.
 * ALL writes are DENIED to clients — only Admin SDK (Cloud Functions) can write.
 *
 * The only exception is the users collection which allows limited reads
 * so the AuthContext can check onboarding status.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // USERS COLLECTION
    // ============================================
    // Client can read their own doc (for AuthContext)
    // ALL writes go through initializeUser / completeOnboarding CFs
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only Admin SDK (Cloud Functions) can write
    }

    // ============================================
    // CREATORS COLLECTION
    // ============================================
    // Creators can read their own profile
    // Brands CANNOT read creators directly — must use getCreatorsForCampaign CF
    //   which strips minRatePrivate before returning data
    // ALL writes go through completeCreatorOnboarding CF
    match /creators/{creatorId} {
      allow read: if request.auth != null && request.auth.uid == creatorId;
      allow write: if false; // Only Admin SDK (Cloud Functions) can write
    }

    // ============================================
    // BRANDS COLLECTION
    // ============================================
    // Brands can read their own profile
    // Creators can read brand profiles (to see who sent requests)
    // ALL writes go through completeBrandOnboarding CF
    match /brands/{brandId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Admin SDK (Cloud Functions) can write
    }

    // ============================================
    // CAMPAIGNS COLLECTION
    // ============================================
    // Active campaigns are readable by any authenticated user
    // Brands can read their own campaigns (including non-active)
    // ALL writes go through createCampaign CF
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Admin SDK (Cloud Functions) can write

      // Pre-computed matches sub-collectionefife
      // Written by onCampaignCreated CF trigger
      match /matches/{matchId} {
        allow read: if false;  // Brands use getCreatorsForCampaign CF instead
        allow write: if false; // Only Admin SDK (Cloud Functions) can write
      }
    }

    // ============================================
    // REQUESTS COLLECTION
    // ============================================
    // Users can read requests where they are brand or creator
    // ALL writes go through createRequest / updateRequestStatus CFs
    match /requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
      allow write: if false; // Only Admin SDK (Cloud Functions) can write
    }

    // ============================================
    // CATCH-ALL: Deny everything else
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
