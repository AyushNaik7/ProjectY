# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# Clerk Authentication (Use PRODUCTION keys for deployment!)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/role-select
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/role-select

# App URL (for production)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Resend Email Service (for notifications)
RESEND_API_KEY=your_resend_api_key

# Node Environment
NODE_ENV=production

# Meta Graph API (Instagram Graph API)
# Access token must belong to a user/app with instagram_basic, pages_show_list,
# instagram_manage_insights, and pages_read_engagement permissions.
META_ACCESS_TOKEN=your_meta_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
GRAPH_API_VERSION=v20.0
INSTAGRAM_POST_LIMIT=25
META_API_TIMEOUT_MS=10000
API_ALLOWED_ORIGIN=*
PORT=5000
